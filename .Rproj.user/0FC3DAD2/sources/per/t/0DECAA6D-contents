knitr_table <- function(x) {
  x %>% 
    knitr::kable(format = "html", digits = Inf, 
                 format.args = list(big.mark = ",")) %>%
    kableExtra::kable_styling(font_size = 15)
}

scale_fill_Reza <- function(...){
  ggplot2:::manual_scale(
    'color', 
    values = setNames(c('#e41a1c', '#377eb8', '#984ea3', '#4daf4a'), c("DEp1", "No DEp1","DEp2", "No DEp2" )), 
    ...
  )
}

scale_fill_chris <- function(...){
  ggplot2:::manual_scale(
    'color', 
    values = setNames(c('green', 'blue', 'red', 'orange'), LETTERS[1:4]), 
    ...
  )
}



Compare_parameters <-  function(df1 , df2, type , extra_info = "") {
  
  df1 <-  df1 %>% 
    dplyr::mutate("Amygdala_DEp" =  factor(if_else(adj.P.Val_Amygdala < 0.05 , "DEp1" , "No DEp1")), 
                  "sACC_DEp" = factor(if_else(adj.P.Val_sACC < 0.05 , "DEp1" , "No DEp1")),
                  "Ext_FC_Amygdala" = factor(if_else( abs (logFC_Amygdala) > 3 , "Extrem FC1" ,"Normal FC1")), 
                  "Ext_FC_sACC" = factor(if_else( abs (logFC_sACC) > 3 , "Extrem FC1" ,"Normal FC1")))
  
  
  df2 <-  df2 %>% 
    dplyr::mutate("Amygdala_DEp" = factor(if_else(adj.P.Val_Amygdala < 0.05 , "DEp2" , "No DEp2")), 
                  "sACC_DEp" = factor(if_else(adj.P.Val_sACC < 0.05 , "DEp2" , "No DEp2")),
                  "Ext_FC_Amygdala" = factor(if_else( abs (logFC_Amygdala) > 3 , "Extrem FC2" ,"Normal FC2")), 
                  "Ext_FC_sACC" = factor(if_else( abs (logFC_sACC) > 3 , "Extrem FC2" ,"Normal FC2")))
  
  p1 <- df1%>%
    ggplot(aes(-log10(P.Value_Amygdala) , t_Amygdala , color = Amygdala_DEp )) +
    geom_point(alpha = 0.7) +
    theme_classic()+
    scale_fill_Reza() +
    labs(subtitle ="Amygdala, BP model, highlighting DEp",
         x ="-log10 p-value", y = "t stat") +
    scale_x_continuous(breaks = seq(0,12,2), limits=c(0, 12)) +
    ylim(-15 , 15)+
    theme(legend.position = "none")+
    geom_vline(xintercept = c(4 , 6), linetype="dotted", 
               color = "grey", linewidth=1) 
  
  
  p2 <- df2%>%
    ggplot(aes(-log10(P.Value_Amygdala) , t_Amygdala , color = Amygdala_DEp )) +
    geom_point(alpha = 0.7) +
    theme_classic()+
    scale_fill_Reza() +
    labs(subtitle ="Amygdala, DP model, highlighting DEp",
         x ="-log10 p-value", y = "t stat") +
    scale_x_continuous(breaks = seq(0,12,2), limits=c(0, 12)) +
    ylim(-15 , 15) +
    theme(legend.position = "none") +
    geom_vline(xintercept = c(4 , 6), linetype="dotted", 
               color = "grey", linewidth=1)
  
  
  p3 <- df1%>%
    ggplot(aes(logFC_Amygdala , t_Amygdala , color = Amygdala_DEp )) +
    geom_point(alpha = 0.7) +
    theme_classic()+
    scale_fill_Reza() +
    labs(subtitle ="Amygdala, BP model, highlighting DEp",
         x ="logFC", y = "t stat") +
    scale_x_continuous(breaks = seq(-10,10,2), limits=c(-10, 10)) +
    ylim(-15 , 15) +
    theme(legend.position = "none") +
    geom_vline(xintercept = c(-3 , 3), linetype="dotted", 
               color = "grey", linewidth=1)
  
  p4 <- df2%>%
    ggplot(aes(logFC_Amygdala , t_Amygdala , color = Amygdala_DEp )) +
    geom_point(alpha = 0.7) +
    theme_classic()+
    scale_fill_Reza() +
    labs(subtitle ="Amygdala, DP model, highlighting DEp",
         x ="logFC", y = "t stat") +
    scale_x_continuous(breaks = seq(-10,10,2), limits=c(-10, 10)) +
    ylim(-15 , 15)+
    theme(legend.position = "none") +
    geom_vline(xintercept = c(-3 , 3), linetype="dotted", 
               color = "grey", linewidth=1)
  
  jpeg(here("graphs", "t_stat" ,  paste0("Scatter plot comparing t stat vs. FC or -log10 pvalue from BP model  and DP model on Amygdala region " , type , extra_info ,  " .jpg")) , width = 7000 , height = 5000  , res = 600)
  
  grid.arrange(p1,p2 , p3 , p4 , top = paste(type , "Amygdala") , bottom = "Comaparing BP and DP model")
  
  dev.off()
  
  
  p5 <- df1%>%
    ggplot(aes(-log10(P.Value_sACC) , t_sACC , color = sACC_DEp )) +
    geom_point(alpha = 0.7) +
    theme_classic()+
    scale_fill_Reza() +
    labs(subtitle ="sACC, BP model, highlighting DEp",
         x ="-log10 p-value", y = "t stat") +
    scale_x_continuous(breaks = seq(0,12,2), limits=c(0, 12)) +
    ylim(-15 , 15)+
    theme(legend.position = "none")+
    geom_vline(xintercept = c(4 , 6), linetype="dotted", 
               color = "grey", linewidth=1)
  
  p6 <- df2%>%
    ggplot(aes(-log10(P.Value_sACC) , t_sACC , color = sACC_DEp )) +
    geom_point(alpha = 0.7) +
    theme_classic()+
    scale_fill_Reza() +
    labs(subtitle ="sACC, DP model, highlighting DEp",
         x ="-log10 p-value", y = "t stat") +
    scale_x_continuous(breaks = seq(0,12,2), limits=c(0, 12)) +
    ylim(-15 , 15) +
    theme(legend.position = "none") +
    geom_vline(xintercept = c(4 , 6), linetype="dotted", 
               color = "grey", linewidth=1)
  
  
  p7 <- df1%>%
    ggplot(aes(logFC_sACC , t_sACC , color = sACC_DEp )) +
    geom_point(alpha = 0.7) +
    theme_classic()+
    scale_fill_Reza() +
    labs(subtitle ="sACC, BP model, highlighting DEp",
         x ="logFC", y = "t stat") +
    scale_x_continuous(breaks = seq(-10,10,2), limits=c(-10, 10)) +
    ylim(-15 , 15) +
    theme(legend.position = "none") +
    geom_vline(xintercept = c(-3 , 3), linetype="dotted", 
               color = "grey", linewidth=1)
  
  p8 <- df2%>%
    ggplot(aes(logFC_sACC , t_sACC , color = sACC_DEp )) +
    geom_point(alpha = 0.7) +
    theme_classic()+
    scale_fill_Reza() +
    labs(subtitle ="sACC, DP model, highlighting DEp",
         x ="logFC", y = "t stat") +
    scale_x_continuous(breaks = seq(-10,10,2), limits=c(-10, 10)) +
    ylim(-15 , 15)+
    theme(legend.position = "none") +
    geom_vline(xintercept = c(-3 , 3), linetype="dotted", 
               color = "grey", linewidth=1)
  
  jpeg(here("graphs", "t_stat" ,  paste0("Scatter plot comparing t stat vs. FC or -log10 pvalue from BP model  and DP model on sACC region " , type , extra_info ,   " .jpg")) , width = 7000 , height = 5000  , res = 600)
  
  grid.arrange(p5,p6 , p7 , p8 , top = paste(type , "sACC") , bottom = "Comaparing BP and DP model")
  
  dev.off()
  
  
  
  
}


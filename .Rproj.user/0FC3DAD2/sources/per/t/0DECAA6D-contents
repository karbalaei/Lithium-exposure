Compare_df <-  function(df1 ,  df2,  type ) {
  
  df1 <-  df1 %>% dplyr::select(c(Id , "t_Amygdala" , "adj.P.Val_Amygdala" , "logFC_Amygdala" ,"t_sACC",  "adj.P.Val_sACC" , "logFC_sACC" ))
  df2 <-  df2 %>% dplyr::select(c(Id , "t_Amygdala" , "adj.P.Val_Amygdala" , "logFC_Amygdala" , "t_sACC",  "adj.P.Val_sACC" , "logFC_sACC" ))
  
  Main_df <-  df1 %>% inner_join(df2 , by = "Id") 
  
  colnames(Main_df) <-  colnames(Main_df) %>% str_replace_all("\\.x" , "\\.BP") %>% str_replace_all("\\.y" , "\\.DP")
  
  Amygdala_df <-  Main_df %>% 
    dplyr::select(c(1 , contains("Amygdala"))) %>%
    dplyr::mutate("DEp" = if_else( (adj.P.Val_Amygdala.DP < 0.05  &  adj.P.Val_Amygdala.BP < 0.05 ), "Both Model" ,
                                   if_else( (adj.P.Val_Amygdala.DP < 0.05  &  adj.P.Val_Amygdala.BP >= 0.05 ), "DP model" ,
                                            if_else( (adj.P.Val_Amygdala.DP >= 0.05  &  adj.P.Val_Amygdala.BP < 0.05 ), "BP model" , "None" ))))%>%
    dplyr::mutate("Ext_FC" = if_else( (abs (logFC_Amygdala.DP) > 3  &  abs(logFC_Amygdala.BP) > 3) , "Both Model" ,
                                      if_else( (abs (logFC_Amygdala.DP) > 3  &  abs (logFC_Amygdala.BP) <= 3 ), "DP model" ,
                                               if_else( (abs (logFC_Amygdala.DP) <= 3 &  abs (logFC_Amygdala.BP) > 3 ), "BP model" , "None" ))))
  
  
  sACC_df <-  Main_df %>% 
    dplyr::select(c(1 , contains("sACC"))) %>% 
    dplyr::mutate("DEp" = if_else( (adj.P.Val_sACC.DP < 0.05  &  adj.P.Val_sACC.BP < 0.05 ), "Both Model" ,
                                   if_else( (adj.P.Val_sACC.DP < 0.05  &  adj.P.Val_sACC.BP >= 0.05 ), "DP model" ,
                                            if_else( (adj.P.Val_sACC.DP >= 0.05  &  adj.P.Val_sACC.BP < 0.05 ), "BP model" , "None" )))) %>%
    dplyr::mutate("Ext_FC" = if_else( (abs (logFC_sACC.DP) > 3  &  abs(logFC_sACC.BP) > 3) , "Both Model" ,
                                      if_else( (abs (logFC_sACC.DP) > 3  &  abs (logFC_sACC.BP) <= 3 ), "DP model" ,
                                               if_else( (abs (logFC_sACC.DP) <= 3 &  abs (logFC_sACC.BP) > 3 ), "BP model" , "None" ))))
  
  p1 <- Amygdala_df%>%
    ggplot(aes(t_Amygdala.BP , t_Amygdala.DP , color = DEp )) +
    geom_point(alpha = 0.5) +
    theme_classic()+
    scale_color_brewer(palette="Dark2") +
    labs(subtitle ="Comapring T stat, highlighting DEp",
         x ="t stat from BP model", y = "t stat from DP model") +
    xlim(-15 , 15) +
    ylim(-15 , 15)
  
  
  p3 <-  Amygdala_df%>%
    ggplot(aes(logFC_Amygdala.BP , logFC_Amygdala.DP , color = Ext_FC )) +
    geom_point(alpha = 0.5) +
    theme_classic()+
    scale_color_brewer(palette="Dark2") +
    labs(subtitle ="Comapring logFC, highlighting FC outliers",
         x ="FC from BP model", y = "FC from DP model") +
    xlim(-10 , 10) +
    ylim(-10 , 10) 
  
  p2 <- Amygdala_df%>%
    ggplot(aes(t_Amygdala.BP , t_Amygdala.DP , color =  Ext_FC)) +
    geom_point(alpha = 0.5) +
    theme_classic()+
    scale_color_brewer(palette="Dark2") +
    labs(subtitle ="Comparing T stat , highlighting FC outliers",
         x ="t stat from BP model", y = "t stat from DP model") +
    xlim(-15 , 15) +
    ylim(-15 , 15)
  
  
  p4 <-  Amygdala_df%>%
    ggplot(aes(logFC_Amygdala.BP , logFC_Amygdala.DP , color = DEp )) +
    geom_point(alpha = 0.5) +
    theme_classic()+
    scale_color_brewer(palette="Dark2") +
    labs(subtitle ="Comapring logFC, highlighting DEp",
         x ="FC from BP model", y = "FC from DP model") +
    xlim(-10 , 10) +
    ylim(-10 , 10) 
  
  
  jpeg(here("graphs", "compare models" ,  paste0("Scatter plot comparing t stat and FC from BP model  and DP model on Amygdala region " , type ,  " .jpg")) , width = 7000 , height = 5000  , res = 600)
  
  grid.arrange(p1,p2 , p3 , p4 , top = paste(type , "Amygdala") , bottom = "Comaparing BP and DP model")
  
  dev.off()
  
  #ggsave( paste0("Scatter plot comparing t stat and FC from BP model  and DP model on Amygdala region " , type ,  " .jpg") , width = 8 , height = 8 )
  
  write.table(Amygdala_df , here("tables" , paste0("Amygdaladala_comparing_BP_DP_model " , type,  " .txt")) , row.names = T , sep = "\t")
  
  p1 <- sACC_df%>%
    ggplot(aes(t_sACC.BP , t_sACC.DP , color = DEp )) +
    geom_point(alpha = 0.5) +
    theme_classic()+
    scale_color_brewer(palette="Dark2") +
    labs(subtitle ="Comapring T stat, highlighting DEp",
         x ="t stat from BP model", y = "t stat from DP model") +
    xlim(-15 , 15) +
    ylim(-15 , 15)
  
  
  p3 <-  sACC_df%>%
    ggplot(aes(logFC_sACC.BP , logFC_sACC.DP , color = Ext_FC )) +
    geom_point(alpha = 0.5) +
    theme_classic()+
    scale_color_brewer(palette="Dark2") +
    labs(subtitle ="Comapring logFC, highlighting FC outliers",
         x ="FC from BP model", y = "FC from DP model") +
    xlim(-10 , 10) +

volcanoplot_fn <-  function(data ,  Genes= Genes, logFC = logFC ,   PValue= PValue , 
                            FDR=FDR , FDR_based= T , output_type = "PDF" , width = 5 , height = 5 ,  
                            legendposition = 'right' , simple_graph=T , topgenes_graph = F , topgenes= 10 , log2_i = 50,
                            FDR_cutoff = 0.05 , pvalue_cutoff = 0.05 ) {
  if (FDR_based == T ) {
    
    data <- data %>% 
      mutate(
        Significance = case_when(
          abs(logFC) >= log2(1 + (log2_i/100) ) & FDR <= 0.1 & FDR > 0.05 ~ "FDR 0.1",
          abs(logFC) >= log2(1 + (log2_i/100) ) & FDR <= 0.05 & FDR > 0.01 ~ "FDR 0.05", 
          abs(logFC) >= log2(1 + (log2_i/100) ) & FDR <= 0.01 & FDR > 0.001 ~ "FDR 0.01",
          abs(logFC) >= log2(1 + (log2_i/100) ) & FDR <= 0.001 ~ "FDR 0.001", 
          TRUE ~ "Unchanged" ), 
        Expression = case_when(logFC >= log2(1 + (log2_i/100) ) & FDR <= FDR_cutoff ~ "Up-regulated",
                               logFC <= -log2(1 + (log2_i/100) ) & FDR <= FDR_cutoff ~ "Down-regulated",
                               TRUE ~ "Unchanged"))
    top_genes <- bind_rows(
      data %>% 
        filter(Expression == 'Up-regulated') %>% 
        arrange(FDR, desc(abs(logFC))) %>% 
        head(topgenes),
      data %>% 

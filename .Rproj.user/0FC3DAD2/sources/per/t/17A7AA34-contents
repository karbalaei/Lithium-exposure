Zero_counts <- function(df_info, count , outdf , logFC_tr ,  Freq_tr , graph_w , graph_h , region , type) {
  
  col_ids_0 <-  df_info %>% dplyr::filter(lithium_group == 0) %>% pull(1) 
  col_ids_1 <-  df_info %>% dplyr::filter(lithium_group == 1) %>% pull(1)
  
  
  Count_0_0 <-  count[ , col_ids_0] %>%rowCounts(useNames = T, value = 0) %>% enframe( name = "Id" , value = "Exposure") 
  
  Count_0_1 <-  count[ , col_ids_1]  %>%rowCounts(useNames = T, value = 0) %>% enframe(name = "Id" ,value = "Control") 
  
  Count_0_All <-  count %>% rowCounts(useNames = T, value = 0) %>% enframe(name = "Id" ,value = "All") 
  
  outdf <-  outdf %>% as.data.frame() %>% rownames_to_column("Id") %>%  dplyr::select(c("Id" , logFC)) 
  
  df_list <- list(Count_0_0, Count_0_1, Count_0_All , outdf)      
  
  outdf_ready <-  df_list %>% reduce(full_join, by='Id') %>% pivot_longer(cols = Exposure:All , names_to = "Group" , values_to = "Frequency")
  
  cols <- c("#1170AA", "#55AD89", "#EF6F6A")
  
  graph1 <-  outdf_ready %>% dplyr::filter(abs(logFC) >= logFC_tr & Frequency >= Freq_tr) %>% 
    ggplot( aes(x= Id )) +
    geom_point( aes(y=abs(logFC) ,  color = "#1170AA")) + coord_flip() + theme_light() + theme(legend.position = 'none')+
    xlab("Id") + ylab("|logFC|")
  
  graph2 <-  outdf_ready %>% dplyr::filter(abs(logFC) >= logFC_tr & Frequency >= Freq_tr) %>% 
    ggplot( aes(x= Id , y=Frequency, color = Group , shape = Group)) +
    geom_point(position = "jitter")+  coord_flip() + theme_light() + theme(axis.title.y=element_blank(),
                                                                           axis.text.y=element_blank(),
                                                                           axis.ticks.y=element_blank() ) 
  
  pdf(here("graphs", "Zero_counts" ,  paste0("FC vs. Zero frequency in lithium study ", region , " "  , type ,  " .pdf")) , width = graph_w , height = graph_h)
  
  grid.arrange(graph1 , graph2 , nrow=1 , top = paste(type , " " , region) , layout_matrix = rbind(c(1, 2, 2),
                                                                                                   c(1, 2, 2))) 
  
  dev.off()
  
}


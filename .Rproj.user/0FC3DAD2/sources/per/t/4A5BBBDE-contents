rse_tx_sACC <- rse_tx[,rse_tx$BrainRegion == "sACC"]


###  Define Models ####
# qSV_mat
load(here("data" ,"qSV_mat.Rdata"), verbose = TRUE)


mod <- model.matrix(~PrimaryDx + AgeDeath + Sex  + 
                              snpPC1 + snpPC2 + snpPC3 + snpPC4 + snpPC5 +
                              mitoRate + rRNA_rate +totalAssignedGene + RIN + abs(ERCCsumLogErr), 
                            data=colData(rse_gene))


qSV_mat_sACC <- qSV_mat[colnames(rse_gene_sACC),] 
qSV_mat_Amygdala <- qSV_mat[colnames(rse_gene_Amygdala),] 



mod_sACC <-  cbind(mod[colnames(rse_gene_sACC),], qSV_mat_sACC) %>% DataFrame()
mod_Amygdala <-  cbind(mod[colnames(rse_gene_Amygdala),], qSV_mat_Amygdala) %>% DataFrame()



## Save Models
save(mod_sACC, mod_Amygdala,  file =here("results" ,  "differental_models.Rdata"))

### RUN DE ####

####  Gene ####

###### sACC #######
dge_sACC = DGEList(counts = assays(rse_gene_sACC)$counts, 
                           genes = rowData(rse_gene_sACC))
dge_sACC = calcNormFactors(dge_sACC)

vGene_sACC = voom(dge_sACC,mod_sACC, plot=F)

fitGene_sACC = lmFit(vGene_sACC)
eBGene_sACC = eBayes(fitGene_sACC)
outGene_sACC = topTable(eBGene_sACC,coef=2,
                                p.value = 1,number=nrow(rse_gene_sACC))
outGene_sACC = outGene_sACC[rownames(rse_gene_sACC),]

message("gene" , " sACC " )

sum(outGene_sACC$adj.P.Val < 0.05) #546


##### Amygdala #######
dge_Amyg = DGEList(counts = assays(rse_gene_Amygdala)$counts, 
                           genes = rowData(rse_gene_Amygdala))


dge_Amyg = calcNormFactors(dge_Amyg)
vGene_Amyg = voom(dge_Amyg,mod_Amygdala, plot=F)

fitGene_Amyg = lmFit(vGene_Amyg)
eBGene_Amyg = eBayes(fitGene_Amyg)
outGene_Amyg = topTable(eBGene_Amyg,coef=2,
                                p.value = 1,number=nrow(rse_gene_Amygdala))
outGene_Amyg = outGene_Amyg[rownames(rse_gene_Amygdala),]

message("gene" , " Amygdala " )

sum(outGene_Amyg$adj.P.Val < 0.05) #335


###### core output #######
nam = c("common_gene_id", "logFC", "AveExpr","t", "P.Value", "adj.P.Val", "B")

geneOut = merge(outGene_Amyg[,nam], outGene_sACC[,nam], by ='row.names', all = TRUE) %>% column_to_rownames("Row.names")

colnames(geneOut) <-  colnames(geneOut) %>% str_replace_all("\\.x" , "\\_Amygdala") %>% str_replace_all("\\.y" , "\\_sACC")


write.csv(geneOut , here("results" ,"patient_DPseqmodel_gene.csv"))

geneOut_list <-  list(outGene_Amyg , outGene_sACC)

names(geneOut_list) <-  c("Amygdala" , "sACC")


save(outGene_Amyg , outGene_sACC ,file =here("results" ,  "patient_DPseqmodel_gene.RData" ))

